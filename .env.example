# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────
POSTGRES_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"
POSTGRES_PRISMA_URL="postgresql://postgres.pool:password@db.pooling.supabase.co:6543/postgres"
POSTGRES_URL_NON_POOLING="postgresql://postgres:password@db.supabase.co:5432/postgres"
READ_REPLICA_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
REDIS_PREFIX="serviceops:"

# ─── Supabase Auth ──────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRY="900"
JWT_REFRESH_EXPIRY="604800"

# ─── M-Pesa Daraja ─────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="your-passkey"
MPESA_BASE_URL="https://sandbox.safaricom.co.ke"
MPESA_CALLBACK_URL="https://api.serviceops.co.ke/api/v1/webhooks/mpesa/callback"
MPESA_B2C_CALLBACK_URL="https://api.serviceops.co.ke/api/v1/webhooks/mpesa/b2c-callback"
MPESA_ENVIRONMENT="sandbox"

# ─── Africa's Talking (SMS) ────────────────────────────────────────────────
AT_API_KEY="your-africas-talking-api-key"
AT_USERNAME="serviceops"
AT_SENDER_ID="SVCOPS"

# ─── WhatsApp Business API ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-waba-phone-id"
WHATSAPP_ACCESS_TOKEN="your-waba-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="serviceops-whatsapp-verify"
WHATSAPP_API_VERSION="v18.0"

# ─── Novu (Notifications) ──────────────────────────────────────────────────
NOVU_API_KEY="your-novu-api-key"
NOVU_API_URL="https://api.novu.co"
NOVU_APP_ID="your-novu-app-id"

# ─── MinIO (File Storage) ──────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="serviceops"
MINIO_SECRET_KEY="serviceops_dev"
MINIO_BUCKET="serviceops-uploads"
MINIO_REGION="us-east-1"
MINIO_USE_SSL="false"
MINIO_PUBLIC_URL="http://localhost:9000"

# ─── Kafka (Optional - Phase 2) ────────────────────────────────────────────
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="serviceops"
KAFKA_USERNAME=""
KAFKA_PASSWORD=""
KAFKA_SASL_MECHANISM="plain"
KAFKA_SSL="false"

# ─── Open AI / Gemini (Optional - Phase 3) ─────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"
