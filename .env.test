NODE_ENV=test

# Database
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serviceops_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serviceops_test

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=test-jwt-secret-do-not-use-in-production

# M-Pesa (Sandbox)
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=test-consumer-key
MPESA_CONSUMER_SECRET=test-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=test-passkey
MPESA_CALLBACK_URL=http://localhost:3001/v1/webhooks/mpesa/callback
MPESA_B2C_CALLBACK_URL=http://localhost:3001/v1/webhooks/mpesa/b2c-callback
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=

# Africa's Talking (Sandbox)
AT_API_URL=https://api.africastalking.com/version1
AT_API_KEY=test-at-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=

# Keycloak (Test)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=serviceops
KEYCLOAK_CLIENT_ID=serviceops-api
KEYCLOAK_CLIENT_SECRET=test-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=admin

# Default
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
